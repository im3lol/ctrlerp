// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// PLATFORM ADMIN & LICENSING
// ============================================

model PlatformAdmin {
  id        String   @id @default(cuid())
  username  String   @unique
  name      String
  email     String?  @unique
  password  String
  role      String   @default("admin") // super_admin, admin
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accessTokens PlatformAdminToken[]
}

model PlatformAdminToken {
  id        String   @id @default(cuid())
  adminId   String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  admin PlatformAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([adminId])
  @@index([createdAt])
}

model Tenant {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phone         String?
  status        String   @default("active") // active, suspended, cancelled
  ownerId       String?  // The user who registered (in tenant DB)
  subdomain     String   @unique @default(cuid()) // e.g., "acme" → acme.ctrlerp.com - default is temp, must be set
  customDomain  String?  @unique // e.g., "erp.acme.com" (optional custom domain)
  databaseName  String?  // e.g., "tenant_acme123" (PostgreSQL database name)
  databaseUrl   String?  // Full connection string for tenant's database
  dbStatus      String   @default("pending") // pending, provisioning, ready, error
  planType      String   @default("trial") // trial, basic, professional, enterprise, lifetime
  maxUsers      Int      @default(5)
  maxCompanies  Int      @default(1)
  logo          String?  // Tenant logo URL
  settings      String?  // JSON string for tenant-specific settings
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companies Company[]
  licenses  License[]
  revenueRecords RevenueRecord[]

  @@index([status])
  @@index([subdomain])
  @@index([customDomain])
  @@index([dbStatus])
  @@index([createdAt])
}

model License {
  id           String   @id @default(cuid())
  tenantId     String
  key          String   @unique
  type         String   // trial, basic, professional, enterprise, lifetime
  status       String   @default("active") // active, expired, suspended, cancelled
  maxUsers     Int      @default(1)
  maxCompanies Int      @default(1)
  isLifetime   Boolean  @default(false)
  price        Float    @default(0) // subscription price paid
  monthlyPrice Float    @default(0) // monthly recurring price for MRR calculation
  currency     String   @default("EGP") // currency of the price
  startedAt    DateTime @default(now())
  expiresAt    DateTime // far future date for lifetime licenses (2099-12-31)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  history   LicenseHistory[]
  revenueRecords RevenueRecord[]

  @@index([tenantId])
  @@index([status])
  @@index([type])
  @@index([isLifetime])
  @@index([expiresAt])
  @@index([status, type])
  @@index([status, isLifetime, expiresAt])
  @@index([createdAt])
}

model LicenseHistory {
  id          String   @id @default(cuid())
  licenseId   String
  action      String   // created, activated, extended, suspended, reactivated, upgraded, cancelled, lifetime_activated, trial_extended, months_extended
  oldStatus   String?
  newStatus   String?
  oldType     String?
  newType     String?
  oldExpiresAt DateTime?
  newExpiresAt DateTime?
  oldPrice    Float?
  newPrice    Float?
  details     String?  // JSON string with extra details
  performedBy String?  // Admin who performed the action
  createdAt   DateTime @default(now())

  license License @relation(fields: [licenseId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String   // tenant_created, tenant_suspended, tenant_activated, license_created, license_activated, license_extended, license_suspended, admin_login, admin_action, user_registered, etc.
  category    String   // tenant, license, auth, system, user
  description String
  performedBy String?  // Admin ID or system
  performerName String? // Admin name
  targetType  String?  // tenant, license, user, etc.
  targetId    String?  // ID of the affected entity
  targetName  String?  // Name of the affected entity
  details     String?  // JSON string with extra info
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([category])
  @@index([createdAt])
  @@index([action])
}

model RevenueRecord {
  id          String   @id @default(cuid())
  tenantId    String
  licenseId   String
  amount      Float
  currency    String   @default("EGP")
  type        String   // subscription, renewal, upgrade, lifetime, trial_extension
  periodStart DateTime?
  periodEnd   DateTime?
  description String?
  createdAt   DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  license License @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([licenseId])
  @@index([createdAt])
  @@index([type])
  @@index([currency])
}

// ============================================
// LOCAL LICENSE STORE (Tenant DB)
// Stores verified license info locally for offline validation
// This model exists in BOTH platform DB and tenant DBs
// ============================================

model LicenseStore {
  id                 String   @id @default(cuid())
  licenseId          String   @unique  // ID from the License model
  licenseKey         String   @unique  // Display key: CTRL-XXXX-XXXX-XXXX
  signedKey          String            // Full base64-encoded signed license key
  tenantId           String            // Platform tenant ID
  type               String            // trial, basic, professional, enterprise, lifetime
  status             String   @default("active") // active, expired, suspended, cancelled
  maxUsers           Int      @default(1)
  maxCompanies       Int      @default(1)
  isLifetime         Boolean  @default(false)
  price              Float    @default(0)
  monthlyPrice       Float    @default(0)
  currency           String   @default("EGP")
  features           String?            // JSON array of enabled features
  machineFingerprint String?            // Hardware binding for client-hosted deployments
  issuedAt           DateTime
  expiresAt          DateTime
  activatedAt        DateTime @default(now())
  lastVerifiedAt     DateTime @default(now())
  verificationCount  Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([licenseKey])
  @@index([status])
  @@index([expiresAt])
  @@index([tenantId])
}

// ============================================
// AUTH & MULTI-COMPANY
// ============================================

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  name      String
  email     String?  @unique
  password  String
  role      String   @default("viewer") // super_admin, admin, accountant, sales, purchase, inventory, viewer
  isActive  Boolean  @default(true)
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyUsers CompanyUser[]
  accessTokens AccessToken[]
}

model AccessToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id              String   @id @default(cuid())
  nameAr          String
  nameEn          String   @default("My Company")
  legalName       String?
  slug            String?  @unique
  address         String?
  phone           String?
  email           String?
  taxNumber       String?
  logo            String?
  baseCurrencyId  String?
  fiscalYearStart String?
  vatRate         Float    @default(14.0)
  status          String   @default("active") // active, inactive
  tenantId        String?  // Reference to platform Tenant (for cross-DB identification)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant           Tenant?        @relation(fields: [tenantId], references: [id])
  companyUsers     CompanyUser[]
  currencies       Currency[]
  unitOfMeasures   UnitOfMeasure[]
  warehouses       Warehouse[]
  itemCategories   ItemCategory[]
  items            Item[]
  accounts         Account[]
  accountMappings  CompanyAccountMapping[]
  journalEntries   JournalEntry[]
  customers        Customer[]
  salesInvoices    SalesInvoice[]
  receiptVouchers  ReceiptVoucher[]
  suppliers        Supplier[]
  purchaseInvoices PurchaseInvoice[]
  paymentVouchers  PaymentVoucher[]
  investors        Investor[]
  investments      Investment[]
  profitDistributions ProfitDistribution[]
  withdrawals      Withdrawal[]
  stockTransfers    StockTransfer[]
  materialRequests  MaterialRequest[]
  deliveryNotes     DeliveryNote[]
  purchaseReceipts  PurchaseReceipt[]
  pickLists         PickList[]
  purchaseOrders    PurchaseOrder[]
  salesOrders       SalesOrder[]
  purchaseReturns   PurchaseReturn[]
  salesReturns      SalesReturn[]
}

model CompanyUser {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  role      String   @default("viewer") // admin, accountant, sales, purchase, inventory, viewer
  isActive  Boolean  @default(true)
  joinedAt  DateTime @default(now())

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
}

// ============================================
// SETTINGS MODULE
// ============================================

model Currency {
  id           String   @id @default(cuid())
  companyId    String
  code         String
  nameAr       String
  nameEn       String
  symbol       String
  isBase       Boolean  @default(false)
  exchangeRate Float    @default(1.0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
}

model UnitOfMeasure {
  id        String   @id @default(cuid())
  companyId String
  code      String
  nameAr    String
  nameEn    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items   Item[]

  @@unique([companyId, code])
}

// ============================================
// INVENTORY MODULE
// ============================================

model Warehouse {
  id        String   @id @default(cuid())
  companyId String
  code      String
  nameAr    String
  nameEn    String?
  type      String   @default("WAREHOUSE") // WAREHOUSE, ZONE, RACK, SHELF, BOX
  parentId  String?
  location  String?
  manager   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company          Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent           Warehouse?       @relation("WarehouseHierarchy", fields: [parentId], references: [id])
  children         Warehouse[]      @relation("WarehouseHierarchy")
  stockMovements   StockMovement[]
  itemBalances     ItemBalance[]
  fifoLayers       FifoLayer[]
  purchaseInvoices PurchaseInvoice[]
  transferFrom     StockTransfer[]  @relation("TransferFrom")
  transferTo       StockTransfer[]  @relation("TransferTo")
  deliveryNotes    DeliveryNote[]
  purchaseReceipts PurchaseReceipt[]
  pickLists        PickList[]
  purchaseOrders   PurchaseOrder[]
  purchaseReturns  PurchaseReturn[]
  salesReturns     SalesReturn[]

  @@unique([companyId, code])
}

model ItemCategory {
  id        String   @id @default(cuid())
  companyId String
  code      String
  nameAr    String
  nameEn    String?
  parentId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent  ItemCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ItemCategory[] @relation("CategoryHierarchy")
  items   Item[]

  @@unique([companyId, code])
}

model Item {
  id          String   @id @default(cuid())
  companyId   String
  code        String
  nameAr      String?  // Optional - not mandatory
  nameEn      String?
  categoryId  String?
  uomId       String?
  costMethod  String   @default("FIFO")
  sellPrice   Float    @default(0)
  minStock    Float    @default(0)
  maxStock    Float?
  description String?
  image       String?  // Product image URL/path
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category        ItemCategory?       @relation(fields: [categoryId], references: [id])
  uom             UnitOfMeasure?      @relation(fields: [uomId], references: [id])
  balances        ItemBalance[]
  fifoLayers      FifoLayer[]
  stockMovements  StockMovement[]
  salesLines      SalesInvoiceLine[]
  purchaseLines   PurchaseInvoiceLine[]
  codes           ItemCode[]
  transferLines        StockTransferLine[]
  materialRequestLines MaterialRequestLine[]
  deliveryNoteLines    DeliveryNoteLine[]
  purchaseReceiptLines PurchaseReceiptLine[]
  pickListLines        PickListLine[]
  purchaseOrderLines   PurchaseOrderLine[]
  salesOrderLines      SalesOrderLine[]
  purchaseReturnLines  PurchaseReturnLine[]
  salesReturnLines     SalesReturnLine[]

  @@unique([companyId, code])
}

model ItemCode {
  id        String   @id @default(cuid())
  itemId    String
  codeType  String   // UPC, EAN, SKU, ASIN, FNSKU, OTHER
  code      String   // The actual code value
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, codeType, code])
  @@map("item_codes")
}

model ItemBalance {
  id          String   @id @default(cuid())
  itemId      String
  warehouseId String
  quantity    Float    @default(0)
  avgCost     Float    @default(0)
  updatedAt   DateTime @updatedAt

  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([itemId, warehouseId])
}

model FifoLayer {
  id                String   @id @default(cuid())
  itemId            String
  warehouseId       String
  quantity          Float
  remaining         Float
  unitCost          Float
  purchaseInvoiceId String?
  date              DateTime
  createdAt         DateTime @default(now())

  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
}

model StockMovement {
  id            String   @id @default(cuid())
  companyId     String
  number        String
  type          String   // IN, OUT, ADJ
  itemId        String
  warehouseId   String
  quantity      Float
  unitCost      Float    @default(0)
  totalCost     Float    @default(0)
  referenceType String?
  referenceId   String?
  reason        String?
  date          DateTime
  createdAt     DateTime @default(now())

  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([companyId, number])
}

model StockTransfer {
  id          String   @id @default(cuid())
  companyId   String
  number      String
  date        DateTime
  fromWarehouseId String  // Source location (warehouse/zone/rack/shelf/box)
  toWarehouseId   String  // Destination location
  status      String   @default("DRAFT") // DRAFT, CONFIRMED, CANCELLED
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse            @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse            @relation("TransferTo", fields: [toWarehouseId], references: [id])
  lines         StockTransferLine[]

  @@unique([companyId, number])
}

model StockTransferLine {
  id             String   @id @default(cuid())
  stockTransferId String
  itemId         String
  quantity       Float
  notes          String?

  stockTransfer StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  item          Item          @relation(fields: [itemId], references: [id])
}

// ─── Stock Transactions ──────────────────────────────────────────────────────

model MaterialRequest {
  id           String   @id @default(cuid())
  companyId    String
  number       String
  date         DateTime
  status       String   @default("DRAFT") // DRAFT, PENDING, APPROVED, FULFILLED, CANCELLED
  requestedBy  String?
  approvedBy   String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   MaterialRequestLine[]

  @@unique([companyId, number])
}

model MaterialRequestLine {
  id               String   @id @default(cuid())
  materialRequestId String
  itemId           String
  quantity         Float
  fulfilledQty     Float    @default(0)
  uomId            String?
  notes            String?

  materialRequest MaterialRequest @relation(fields: [materialRequestId], references: [id], onDelete: Cascade)
  item            Item            @relation(fields: [itemId], references: [id])
}

model DeliveryNote {
  id             String   @id @default(cuid())
  companyId      String
  number         String
  date           DateTime
  status         String   @default("DRAFT") // DRAFT, CONFIRMED, CANCELLED
  salesInvoiceId String?
  salesOrderId   String?
  customerId     String?
  warehouseId    String
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  salesInvoice SalesInvoice?      @relation(fields: [salesInvoiceId], references: [id])
  salesOrder   SalesOrder?        @relation(fields: [salesOrderId], references: [id])
  customer     Customer?          @relation(fields: [customerId], references: [id])
  warehouse    Warehouse          @relation(fields: [warehouseId], references: [id])
  lines        DeliveryNoteLine[]
  salesReturns SalesReturn[]

  @@unique([companyId, number])
}

model DeliveryNoteLine {
  id              String   @id @default(cuid())
  deliveryNoteId  String
  itemId          String
  quantity        Float
  salesInvoiceLineId String?
  notes           String?

  deliveryNote    DeliveryNote     @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  item            Item             @relation(fields: [itemId], references: [id])
}

model PurchaseReceipt {
  id               String   @id @default(cuid())
  companyId        String
  number           String
  date             DateTime
  status           String   @default("DRAFT") // DRAFT, CONFIRMED, CANCELLED
  purchaseInvoiceId String?
  purchaseOrderId  String?
  supplierId       String?
  warehouseId      String
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company        Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseInvoice PurchaseInvoice?    @relation(fields: [purchaseInvoiceId], references: [id])
  purchaseOrder  PurchaseOrder?      @relation(fields: [purchaseOrderId], references: [id])
  supplier       Supplier?            @relation(fields: [supplierId], references: [id])
  warehouse      Warehouse            @relation(fields: [warehouseId], references: [id])
  lines          PurchaseReceiptLine[]
  purchaseReturns PurchaseReturn[]

  @@unique([companyId, number])
}

model PurchaseReceiptLine {
  id                 String   @id @default(cuid())
  purchaseReceiptId  String
  itemId             String
  quantity           Float
  purchaseInvoiceLineId String?
  notes              String?

  purchaseReceipt PurchaseReceipt @relation(fields: [purchaseReceiptId], references: [id], onDelete: Cascade)
  item            Item            @relation(fields: [itemId], references: [id])
}

model PickList {
  id          String   @id @default(cuid())
  companyId   String
  number      String
  date        DateTime
  status      String   @default("DRAFT") // DRAFT, IN_PROGRESS, COMPLETED, CANCELLED
  warehouseId String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouse Warehouse       @relation(fields: [warehouseId], references: [id])
  lines     PickListLine[]

  @@unique([companyId, number])
}

model PickListLine {
  id             String   @id @default(cuid())
  pickListId     String
  itemId         String
  quantity       Float
  pickedQty      Float    @default(0)
  salesInvoiceId String?
  notes          String?

  pickList     PickList     @relation(fields: [pickListId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id])

  @@map("pick_list_lines")
}

// ============================================
// ACCOUNTING MODULE
// ============================================

model Account {
  id        String   @id @default(cuid())
  companyId String
  code      String
  nameAr    String
  nameEn    String?
  type      String   // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  parentId  String?
  isLeaf    Boolean  @default(true)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent     Account?           @relation("AccountHierarchy", fields: [parentId], references: [id])
  children   Account[]          @relation("AccountHierarchy")
  entryLines JournalEntryLine[]
  accountMappings CompanyAccountMapping[]

  @@unique([companyId, code])
}

// Maps logical account roles to actual account IDs per company
// This decouples business logic from hardcoded account codes
model CompanyAccountMapping {
  id        String  @id @default(cuid())
  companyId String
  role      String  // Logical role: DEFAULT_CASH, DEFAULT_BANK, DEFAULT_CUSTOMER, etc.
  accountId String  // FK to the actual account
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([companyId, role]) // One mapping per role per company
}

model JournalEntry {
  id           String   @id @default(cuid())
  companyId    String
  number       String
  date         DateTime
  description  String?
  status       String   @default("DRAFT") // DRAFT, POSTED, REVERSED
  sourceType   String?
  sourceId     String?
  reversedById String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company    Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines      JournalEntryLine[]
  reversedBy JournalEntry?      @relation("JournalReversal", fields: [reversedById], references: [id])
  reversalOf JournalEntry[]     @relation("JournalReversal")

  @@unique([companyId, number])
}

model JournalEntryLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Float    @default(0)
  credit         Float    @default(0)
  description    String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])
}

// ============================================
// SALES MODULE
// ============================================

model Customer {
  id           String   @id @default(cuid())
  companyId    String
  code         String
  nameAr       String
  nameEn       String?
  phone        String?
  email        String?
  address      String?
  balance      Float    @default(0)
  creditLimit  Float    @default(0)
  paymentTerms Int      @default(30)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  salesInvoices   SalesInvoice[]
  receiptVouchers ReceiptVoucher[]
  deliveryNotes   DeliveryNote[]
  salesOrders     SalesOrder[]
  salesReturns    SalesReturn[]

  @@unique([companyId, code])
}

model SalesInvoice {
  id              String   @id @default(cuid())
  companyId       String
  number          String
  customerId      String
  date            DateTime
  dueDate         DateTime?
  status          String   @default("DRAFT")
  subtotal        Float    @default(0)
  discountAmount  Float    @default(0)
  discountPercent Float    @default(0)
  taxAmount       Float    @default(0)
  taxPercent      Float    @default(0)
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  balanceDue      Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company    Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer           @relation(fields: [customerId], references: [id])
  lines      SalesInvoiceLine[]
  receiptLines ReceiptLine[]
  deliveryNotes DeliveryNote[]
  salesReturns SalesReturn[]

  @@unique([companyId, number])
}

model SalesInvoiceLine {
  id             String   @id @default(cuid())
  salesInvoiceId String
  itemId         String
  quantity       Float
  unitPrice      Float
  discountAmount Float    @default(0)
  taxAmount      Float    @default(0)
  totalAmount    Float
  costAmount     Float    @default(0)

  salesInvoice SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id])
}

model ReceiptVoucher {
  id            String   @id @default(cuid())
  companyId     String
  number        String
  customerId    String
  date          DateTime
  amount        Float
  paymentMethod String   @default("CASH")
  reference     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company  Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer     @relation(fields: [customerId], references: [id])
  lines    ReceiptLine[]

  @@unique([companyId, number])
}

model ReceiptLine {
  id               String   @id @default(cuid())
  receiptVoucherId String
  salesInvoiceId   String
  amount           Float

  receiptVoucher ReceiptVoucher @relation(fields: [receiptVoucherId], references: [id], onDelete: Cascade)
  salesInvoice   SalesInvoice   @relation(fields: [salesInvoiceId], references: [id])
}

// ============================================
// PURCHASES MODULE
// ============================================

model Supplier {
  id           String   @id @default(cuid())
  companyId    String
  code         String
  nameAr       String
  nameEn       String?
  phone        String?
  email        String?
  address      String?
  balance      Float    @default(0)
  paymentTerms Int      @default(30)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company          Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseInvoices PurchaseInvoice[]
  paymentVouchers  PaymentVoucher[]
  purchaseReceipts PurchaseReceipt[]
  purchaseOrders   PurchaseOrder[]
  purchaseReturns  PurchaseReturn[]

  @@unique([companyId, code])
}

model PurchaseInvoice {
  id              String   @id @default(cuid())
  companyId       String
  number          String
  supplierId      String
  warehouseId     String
  date            DateTime
  dueDate         DateTime?
  status          String   @default("DRAFT")
  subtotal        Float    @default(0)
  discountAmount  Float    @default(0)
  discountPercent Float    @default(0)
  taxAmount       Float    @default(0)
  taxPercent      Float    @default(0)
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  balanceDue      Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company    Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  warehouse  Warehouse           @relation(fields: [warehouseId], references: [id])
  lines      PurchaseInvoiceLine[]
  paymentLines PaymentLine[]
  purchaseReceipts PurchaseReceipt[]
  purchaseReturns PurchaseReturn[]

  @@unique([companyId, number])
}

model PurchaseInvoiceLine {
  id                String   @id @default(cuid())
  purchaseInvoiceId String
  itemId            String
  quantity          Float
  unitPrice         Float
  discountAmount    Float    @default(0)
  taxAmount         Float    @default(0)
  totalAmount       Float

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  item            Item            @relation(fields: [itemId], references: [id])
}

model PaymentVoucher {
  id            String   @id @default(cuid())
  companyId     String
  number        String
  supplierId    String
  date          DateTime
  amount        Float
  paymentMethod String   @default("CASH")
  reference     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company  Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier Supplier     @relation(fields: [supplierId], references: [id])
  lines    PaymentLine[]

  @@unique([companyId, number])
}

model PaymentLine {
  id                String   @id @default(cuid())
  paymentVoucherId  String
  purchaseInvoiceId String
  amount            Float

  paymentVoucher  PaymentVoucher  @relation(fields: [paymentVoucherId], references: [id], onDelete: Cascade)
  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id])
}

// ─── Purchase Orders ──────────────────────────────────────────────────────────

model PurchaseOrder {
  id              String   @id @default(cuid())
  companyId       String
  number          String
  supplierId      String
  warehouseId     String
  date            DateTime
  status          String   @default("DRAFT") // DRAFT, CONFIRMED, CANCELLED, CLOSED
  subtotal        Float    @default(0)
  discountAmount  Float    @default(0)
  discountPercent Float    @default(0)
  taxAmount       Float    @default(0)
  taxPercent      Float    @default(0)
  totalAmount     Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company    Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  warehouse  Warehouse           @relation(fields: [warehouseId], references: [id])
  lines      PurchaseOrderLine[]
  purchaseReceipts PurchaseReceipt[]
  purchaseReturns  PurchaseReturn[]

  @@unique([companyId, number])
}

model PurchaseOrderLine {
  id               String   @id @default(cuid())
  purchaseOrderId  String
  itemId           String
  quantity         Float
  receivedQty      Float    @default(0)
  unitPrice        Float    @default(0)
  discountAmount   Float    @default(0)
  taxAmount        Float    @default(0)
  totalAmount      Float    @default(0)
  notes            String?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  item          Item          @relation(fields: [itemId], references: [id])
}

// ─── Sales Orders ─────────────────────────────────────────────────────────────

model SalesOrder {
  id              String   @id @default(cuid())
  companyId       String
  number          String
  customerId      String
  date            DateTime
  dueDate         DateTime?
  status          String   @default("DRAFT") // DRAFT, CONFIRMED, CANCELLED, CLOSED
  subtotal        Float    @default(0)
  discountAmount  Float    @default(0)
  discountPercent Float    @default(0)
  taxAmount       Float    @default(0)
  taxPercent      Float    @default(0)
  totalAmount     Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company    Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer          @relation(fields: [customerId], references: [id])
  lines      SalesOrderLine[]
  deliveryNotes DeliveryNote[]
  salesReturns  SalesReturn[]

  @@unique([companyId, number])
}

model SalesOrderLine {
  id             String   @id @default(cuid())
  salesOrderId   String
  itemId         String
  quantity       Float
  deliveredQty   Float    @default(0)
  unitPrice      Float    @default(0)
  discountAmount Float    @default(0)
  taxAmount      Float    @default(0)
  totalAmount    Float    @default(0)
  notes          String?

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  item       Item       @relation(fields: [itemId], references: [id])
}

// ============================================
// INVESTORS MODULE
// ============================================

model Investor {
  id          String   @id @default(cuid())
  companyId   String
  code        String   // INV-001
  fullName    String
  phone       String?
  email       String?
  nationalId  String?
  joinDate    DateTime @default(now())
  status      String   @default("active") // active, inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  investments        Investment[]
  investorShares     InvestorShare[]
  withdrawals        Withdrawal[]

  @@unique([companyId, code])
}

model Investment {
  id          String   @id @default(cuid())
  companyId   String
  investorId  String
  date        DateTime
  amount      Float
  type        String   @default("cash") // cash, bank, asset
  accountId   String?  // Which bank/cash account received it
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  investor   Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
}

model ProfitDistribution {
  id               String   @id @default(cuid())
  companyId        String
  periodName       String   // Q1 2026, H1 2026
  periodStart      DateTime
  periodEnd        DateTime
  totalProfit      Float    @default(0)
  distributionDate DateTime
  status           String   @default("DRAFT") // DRAFT, DISTRIBUTED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  investorShares InvestorShare[]
}

model InvestorShare {
  id               String   @id @default(cuid())
  distributionId   String
  investorId       String
  ownershipPercent Float    @default(0)
  profitShare      Float    @default(0)
  status           String   @default("PENDING") // PENDING, PAID
  paymentDate      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  distribution ProfitDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  investor     Investor           @relation(fields: [investorId], references: [id], onDelete: Cascade)
}

model Withdrawal {
  id          String   @id @default(cuid())
  companyId   String
  investorId  String
  date        DateTime
  amount      Float
  type        String   @default("profit") // capital, profit
  accountId   String?  // Paid from which account
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
}

// ============================================
// RETURNS MODULE
// ============================================

model PurchaseReturn {
  id               String   @id @default(cuid())
  companyId        String
  number           String   // PRET-0001
  date             DateTime
  status           String   @default("DRAFT") // DRAFT, CONFIRMED, CANCELLED
  supplierId       String
  warehouseId      String
  purchaseOrderId  String?
  purchaseInvoiceId String?
  purchaseReceiptId String?
  totalAmount      Float    @default(0)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier        Supplier            @relation(fields: [supplierId], references: [id])
  warehouse       Warehouse           @relation(fields: [warehouseId], references: [id])
  purchaseOrder   PurchaseOrder?      @relation(fields: [purchaseOrderId], references: [id])
  purchaseInvoice PurchaseInvoice?    @relation(fields: [purchaseInvoiceId], references: [id])
  purchaseReceipt PurchaseReceipt?    @relation(fields: [purchaseReceiptId], references: [id])
  lines           PurchaseReturnLine[]

  @@unique([companyId, number])
}

model PurchaseReturnLine {
  id              String   @id @default(cuid())
  purchaseReturnId String
  itemId          String
  quantity        Float
  unitPrice       Float    @default(0)
  totalAmount     Float    @default(0)
  notes           String?

  purchaseReturn  PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  item            Item           @relation(fields: [itemId], references: [id])
}

model SalesReturn {
  id              String   @id @default(cuid())
  companyId       String
  number          String   // SRET-0001
  date            DateTime
  status          String   @default("DRAFT") // DRAFT, CONFIRMED, CANCELLED
  customerId      String
  warehouseId     String
  salesOrderId    String?
  salesInvoiceId  String?
  deliveryNoteId  String?
  totalAmount     Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer       Customer         @relation(fields: [customerId], references: [id])
  warehouse      Warehouse        @relation(fields: [warehouseId], references: [id])
  salesOrder     SalesOrder?      @relation(fields: [salesOrderId], references: [id])
  salesInvoice   SalesInvoice?    @relation(fields: [salesInvoiceId], references: [id])
  deliveryNote   DeliveryNote?    @relation(fields: [deliveryNoteId], references: [id])
  lines          SalesReturnLine[]

  @@unique([companyId, number])
}

model SalesReturnLine {
  id            String   @id @default(cuid())
  salesReturnId String
  itemId        String
  quantity      Float
  unitPrice     Float    @default(0)
  totalAmount   Float    @default(0)
  notes         String?

  salesReturn   SalesReturn @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)
  item          Item        @relation(fields: [itemId], references: [id])
}
